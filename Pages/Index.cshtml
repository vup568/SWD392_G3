@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- Hero Banner -->
<div class="bg-primary text-white rounded-3 p-5 mb-5 text-center">
    <h1 class="display-5 fw-bold">Welcome to Online Shop</h1>
    <p class="lead">Quality products delivered to your door. Pay on delivery!</p>
    <a class="btn btn-light btn-lg mt-2" asp-page="/Shop/Products">🛍️ Shop Now</a>
</div>

<!-- Categories -->
@if (Model.Categories.Any())
{
    <h4 class="mb-3">Browse by Category</h4>
    <div class="d-flex flex-wrap gap-2 mb-5">
        @foreach (var cat in Model.Categories)
        {
            <a asp-page="/Shop/Products" asp-route-categoryId="@cat.CategoryId"
               class="btn btn-outline-secondary">@cat.CategoryName</a>
        }
    </div>
}

<!-- Featured Products -->
<h4 class="mb-3">Featured Products</h4>
<div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-4">
    @foreach (var p in Model.FeaturedProducts)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                @if (!string.IsNullOrEmpty(p.ImageUrl))
                {
                    <img src="@p.ImageUrl" class="card-img-top" style="height:180px;object-fit:cover;" alt="@p.ProductName" />
                }
                else
                {
                    <div class="bg-light d-flex align-items-center justify-content-center" style="height:180px;">
                        <span class="text-muted fs-1">🛒</span>
                    </div>
                }
                <div class="card-body d-flex flex-column">
                    <h6 class="card-title">@p.ProductName</h6>
                    <p class="text-muted small">@p.Category?.CategoryName</p>
                    <p class="fw-bold text-primary mt-auto">@p.Price.ToString("N0") ₫</p>
                    <a asp-page="/Shop/ProductDetail" asp-route-id="@p.ProductId"
                       class="btn btn-primary btn-sm mt-2">View Details</a>
                </div>
            </div>
        </div>
    }
</div>
