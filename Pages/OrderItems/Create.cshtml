@page
@model OnlineShopWeb.Pages_OrderItems.CreateModel

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Create</title>
</head>
<body>

<h4>OrderItem</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="OrderItem.OrderId" class="control-label"></label>
                <select asp-for="OrderItem.OrderId" class ="form-control" asp-items="ViewBag.OrderId" ></select>
            </div>
            <div class="form-group">
                <label asp-for="OrderItem.ProductId" class="control-label"></label>
                <select asp-for="OrderItem.ProductId" class ="form-control" asp-items="ViewBag.ProductId" ></select>
            </div>
            <div class="form-group">
                <label asp-for="OrderItem.Quantity" class="control-label"></label>
                <input asp-for="OrderItem.Quantity" class="form-control" />
                <span asp-validation-for="OrderItem.Quantity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="OrderItem.Price" class="control-label"></label>
                <input asp-for="OrderItem.Price" class="form-control" />
                <span asp-validation-for="OrderItem.Price" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
</body>
</html>
