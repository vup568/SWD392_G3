<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Online Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .navbar-brand { font-weight: bold; font-size: 1.4rem; }
        .cart-badge { font-size: 0.7rem; }
    </style>
</head>
<body>
@using Microsoft.AspNetCore.Http
<header>
    <nav class="navbar navbar-expand-sm navbar-dark bg-primary shadow-sm mb-4">
        <div class="container">
            <a class="navbar-brand" asp-page="/Index">🛒 Online Shop</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Shop/Products">Products</a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Shop/Cart">🛒 Cart</a>
                    </li>
                    @if (Context.Session.GetString("UserName") == null)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Account/Login">Login</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <span class="nav-link">👤 @Context.Session.GetString("UserName")</span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Account/Logout">Logout</a>
                        </li>
                        @if (Context.Session.GetString("UserRole") == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Admin/Dashboard">⚙️ Admin</a>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>
<div class="container">
    <main role="main" class="pb-4">
        @RenderBody()
    </main>
</div>
<footer class="border-top footer text-muted py-3 mt-4">
    <div class="container text-center">
        &copy; 2026 Online Shop — Cash on Delivery available 🚚
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
