@page
@model OnlineShopWeb.Pages_Users.EditModel

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Edit</title>
</head>
<body>

<h4>User</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="UserData.UserId" />
            <div class="form-group">
                <label asp-for="UserData.FullName" class="control-label"></label>
                <input asp-for="UserData.FullName" class="form-control" />
                <span asp-validation-for="UserData.FullName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UserData.Email" class="control-label"></label>
                <input asp-for="UserData.Email" class="form-control" />
                <span asp-validation-for="UserData.Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UserData.PasswordHash" class="control-label"></label>
                <input asp-for="UserData.PasswordHash" class="form-control" />
                <span asp-validation-for="UserData.PasswordHash" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UserData.Phone" class="control-label"></label>
                <input asp-for="UserData.Phone" class="form-control" />
                <span asp-validation-for="UserData.Phone" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UserData.Address" class="control-label"></label>
                <input asp-for="UserData.Address" class="form-control" />
                <span asp-validation-for="UserData.Address" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UserData.RoleId" class="control-label"></label>
                <select asp-for="UserData.RoleId" class="form-control" asp-items="ViewBag.RoleId" ></select>
                <span asp-validation-for="UserData.RoleId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UserData.Status" class="control-label"></label>
                <input asp-for="UserData.Status" class="form-control" />
                <span asp-validation-for="UserData.Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UserData.CreatedAt" class="control-label"></label>
                <input asp-for="UserData.CreatedAt" class="form-control" />
                <span asp-validation-for="UserData.CreatedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
</body>
</html>
