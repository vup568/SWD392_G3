@{ ViewData["Title"] = "Change Password"; }
<div class="row justify-content-center mt-4">
  <div class="col-md-5"><div class="card p-4">
    <h4><i class="bi bi-key"></i> Change Password</h4><hr/>
    @if (ViewBag.Error != null) { <div class="alert alert-danger">@ViewBag.Error</div> }
    <form method="post">
      <div class="mb-3"><label class="form-label">Current Password</label><input type="password" name="oldPassword" class="form-control" required /></div>
      <div class="mb-3"><label class="form-label">New Password</label><input type="password" name="newPassword" class="form-control" required /></div>
      <div class="mb-3"><label class="form-label">Confirm New Password</label><input type="password" name="confirmPassword" class="form-control" required /></div>
      <button type="submit" class="btn btn-warning">Change Password</button>
      <a href="/Account/Profile" class="btn btn-outline-secondary ms-2">Cancel</a>
    </form>
  </div></div>
</div>
