@{ ViewData["Title"] = "New Post"; }
<div class="row justify-content-center"><div class="col-md-8"><div class="card p-4">
  <h4><i class="bi bi-plus-circle"></i> New Post</h4><hr/>
  <form method="post">
    <div class="mb-3"><label class="form-label">Title</label><input name="Title" class="form-control" required /></div>
    <div class="mb-3"><label class="form-label">Content</label><textarea name="Content" class="form-control" rows="10"></textarea></div>
    <button type="submit" class="btn btn-success">Publish</button>
    <a href="/Blog/Manage" class="btn btn-outline-secondary ms-2">Cancel</a>
  </form>
</div></div></div>
