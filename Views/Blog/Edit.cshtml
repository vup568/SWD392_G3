@model SWD392_MVC.Models.Post
@{ ViewData["Title"] = "Edit Post"; }
<div class="row justify-content-center"><div class="col-md-8"><div class="card p-4">
  <h4><i class="bi bi-pencil"></i> Edit Post</h4><hr/>
  <form method="post">
    <input type="hidden" name="PostId" value="@Model.PostId" />
    <div class="mb-3"><label class="form-label">Title</label><input name="Title" value="@Model.Title" class="form-control" required /></div>
    <div class="mb-3"><label class="form-label">Content</label><textarea name="Content" class="form-control" rows="10">@Model.Content</textarea></div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a href="/Blog/Manage" class="btn btn-outline-secondary ms-2">Cancel</a>
  </form>
</div></div></div>
