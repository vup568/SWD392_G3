@model IList<SWD392_MVC.Models.ProductCategory>
@{ ViewData["Title"] = "Product Categories"; }
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4><i class="bi bi-tags"></i> Product Categories</h4>
  <div class="d-flex gap-2">
    <a href="/Config/Roles" class="btn btn-outline-secondary btn-sm">Roles</a>
    <a href="/Config/Settings" class="btn btn-outline-secondary btn-sm">Settings</a>
    <a href="/Config/CreateCategory" class="btn btn-success btn-sm"><i class="bi bi-plus"></i> Add</a>
  </div>
</div>
<table class="table table-hover">
  <thead class="table-dark"><tr><th>Name</th><th>Status</th><th>Actions</th></tr></thead>
  <tbody>
    @foreach (var c in Model) {
      <tr><td>@c.CategoryName</td>
        <td><span class="badge @(c.Status==true?"bg-success":"bg-secondary")">@(c.Status==true?"Active":"Hidden")</span></td>
        <td>
          <a href="/Config/EditCategory/@c.CategoryId" class="btn btn-sm btn-warning">Edit</a>
          <a href="/Config/ToggleCategory/@c.CategoryId" class="btn btn-sm @(c.Status==true?"btn-secondary":"btn-success")">@(c.Status==true?"Hide":"Show")</a>
        </td>
      </tr>
    }
  </tbody>
</table>
