@{ ViewData["Title"] = "Add Role"; }
<div class="row justify-content-center"><div class="col-md-5"><div class="card p-4">
  <h4>Add Role</h4><hr/>
  <form method="post">
    <div class="mb-3"><label class="form-label">Role Name</label><input name="RoleName" class="form-control" required /></div>
    <button type="submit" class="btn btn-success">Create</button>
    <a href="/Config/Roles" class="btn btn-outline-secondary ms-2">Cancel</a>
  </form>
</div></div></div>
