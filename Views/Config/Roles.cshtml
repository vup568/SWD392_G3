@model IList<SWD392_MVC.Models.Role>
@{ ViewData["Title"] = "Roles"; }
<div class="d-flex justify-content-between mb-3">
  <h4><i class="bi bi-shield-check"></i> Roles</h4>
  <a href="/Config/CreateRole" class="btn btn-success btn-sm"><i class="bi bi-plus"></i> Add Role</a>
</div>
<table class="table table-hover">
  <thead class="table-dark"><tr><th>ID</th><th>Role Name</th><th>Actions</th></tr></thead>
  <tbody>
    @foreach (var r in Model) {
      <tr><td>@r.RoleId</td><td>@r.RoleName</td>
        <td><a href="/Config/EditRole/@r.RoleId" class="btn btn-sm btn-warning">Edit</a></td>
      </tr>
    }
  </tbody>
</table>
