@model SWD392_MVC.Models.User
@{ ViewData["Title"] = "Edit User"; }
<div class="row justify-content-center"><div class="col-md-6"><div class="card p-4">
  <h4>Edit User: @Model.FullName</h4><hr/>
  <form method="post">
    <input type="hidden" name="UserId" value="@Model.UserId"/>
    <div class="mb-3"><label class="form-label">Full Name</label><input name="FullName" value="@Model.FullName" class="form-control" /></div>
    <div class="mb-3"><label class="form-label">Email</label><input name="Email" value="@Model.Email" class="form-control" /></div>
    <div class="mb-3"><label class="form-label">Phone</label><input name="Phone" value="@Model.Phone" class="form-control" /></div>
    <div class="mb-3"><label class="form-label">Address</label><input name="Address" value="@Model.Address" class="form-control" /></div>
    <div class="mb-3"><label class="form-label">Role</label>
      <select name="RoleId" class="form-select">
        @foreach (var r in (IList<SWD392_MVC.Models.Role>)ViewBag.Roles) {
          <option value="@r.RoleId" selected="@(r.RoleId==Model.RoleId)">@r.RoleName</option>
        }
      </select>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a href="/Dashboard/Users" class="btn btn-outline-secondary ms-2">Cancel</a>
  </form>
</div></div></div>
