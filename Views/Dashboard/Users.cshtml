@model IList<SWD392_MVC.Models.User>
@{ ViewData["Title"] = "User Management"; }
<h4 class="mb-3"><i class="bi bi-people-fill"></i> User Management</h4>
<form method="get" class="row g-2 mb-3">
  <div class="col-md-4"><input name="search" class="form-control" placeholder="Search name/email..."/></div>
  <div class="col-md-3">
    <select name="roleId" class="form-select">
      <option value="">All Roles</option>
      @foreach (var r in (IList<SWD392_MVC.Models.Role>)ViewBag.Roles) { <option value="@r.RoleId">@r.RoleName</option> }
    </select>
  </div>
  <div class="col-md-2"><select name="status" class="form-select"><option value="">All</option><option value="true">Active</option><option value="false">Inactive</option></select></div>
  <div class="col-md-2"><button type="submit" class="btn btn-primary w-100">Filter</button></div>
</form>
<table class="table table-hover table-sm">
  <thead class="table-dark"><tr><th>Name</th><th>Email</th><th>Role</th><th>Phone</th><th>Status</th><th>Actions</th></tr></thead>
  <tbody>
    @foreach (var u in Model) {
      <tr>
        <td>@u.FullName</td><td>@u.Email</td><td><span class="badge bg-secondary">@u.Role?.RoleName</span></td>
        <td>@u.Phone</td>
        <td><span class="badge @(u.Status==true?"bg-success":"bg-danger")">@(u.Status==true?"Active":"Inactive")</span></td>
        <td>
          <a href="/Dashboard/EditUser/@u.UserId" class="btn btn-sm btn-warning">Edit</a>
          <a href="/Dashboard/ToggleUser/@u.UserId" class="btn btn-sm @(u.Status==true?"btn-secondary":"btn-success")">@(u.Status==true?"Deactivate":"Activate")</a>
          <a href="/Dashboard/ResetPassword/@u.UserId" class="btn btn-sm btn-outline-danger" onclick="return confirm('Reset password to 123?')">Reset Pwd</a>
        </td>
      </tr>
    }
  </tbody>
</table>
