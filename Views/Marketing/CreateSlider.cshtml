@{ ViewData["Title"] = "Add Slider"; }
<div class="row justify-content-center"><div class="col-md-6"><div class="card p-4">
  <h4>Add Slider</h4><hr/>
  <form method="post">
    <div class="mb-3"><label class="form-label">Title</label><input name="Title" class="form-control" /></div>
    <div class="mb-3"><label class="form-label">Image URL</label><input name="ImageUrl" class="form-control" /></div>
    <div class="mb-3"><label class="form-label">Link</label><input name="Link" class="form-control" /></div>
    <button type="submit" class="btn btn-success">Create</button>
    <a href="/Marketing/Sliders" class="btn btn-outline-secondary ms-2">Cancel</a>
  </form>
</div></div></div>
