@model SWD392_MVC.Models.Slider
@{ ViewData["Title"] = "Edit Slider"; }
<div class="row justify-content-center"><div class="col-md-6"><div class="card p-4">
  <h4>Edit Slider</h4><hr/>
  <form method="post">
    <input type="hidden" name="SliderId" value="@Model.SliderId"/>
    <div class="mb-3"><label class="form-label">Title</label><input name="Title" value="@Model.Title" class="form-control" /></div>
    <div class="mb-3"><label class="form-label">Image URL</label><input name="ImageUrl" value="@Model.ImageUrl" class="form-control" /></div>
    <div class="mb-3"><label class="form-label">Link</label><input name="Link" value="@Model.Link" class="form-control" /></div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a href="/Marketing/Sliders" class="btn btn-outline-secondary ms-2">Cancel</a>
  </form>
</div></div></div>
