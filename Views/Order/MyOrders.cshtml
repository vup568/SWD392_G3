@model IList<SWD392_MVC.Models.Order>
@{ ViewData["Title"] = "My Orders"; }
<h4 class="mb-3"><i class="bi bi-bag-check"></i> My Orders</h4>
@if (!Model.Any()) { <div class="alert alert-info">You haven't placed any orders yet. <a href="/Product/Index">Shop now!</a></div> }
else {
  <table class="table table-hover">
    <thead class="table-dark"><tr><th>Order #</th><th>Date</th><th>Total</th><th>Status</th><th></th></tr></thead>
    <tbody>
      @foreach (var o in Model) {
        <tr>
          <td>#@o.OrderId</td>
          <td>@o.OrderDate?.ToString("dd/MM/yyyy HH:mm")</td>
          <td class="fw-bold text-primary">@o.TotalAmount?.ToString("N0") ₫</td>
          <td><span class="badge @(o.Status=="Completed"?"bg-success":o.Status=="Cancelled"?"bg-danger":"bg-warning text-dark")">@o.Status</span></td>
          <td>
            <a href="/Order/MyOrderDetail/@o.OrderId" class="btn btn-sm btn-outline-primary">Detail</a>
            @if (o.Status == "Submitted") { <a href="/Order/Cancel/@o.OrderId" class="btn btn-sm btn-outline-danger ms-1" onclick="return confirm('Cancel this order?')">Cancel</a> }
          </td>
        </tr>
      }
    </tbody>
  </table>
}
