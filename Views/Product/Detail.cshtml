@model SWD392_MVC.Models.Product
@{ ViewData["Title"] = Model.ProductName; }

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/">Home</a></li>
    <li class="breadcrumb-item"><a href="/Product/Index">Products</a></li>
    <li class="breadcrumb-item active">@Model.ProductName</li>
  </ol>
</nav>

<div class="row g-4">
  <div class="col-md-5">
    @if (!string.IsNullOrEmpty(Model.ImageUrl)) {
      <img src="@Model.ImageUrl" class="img-fluid rounded-3 shadow" alt="@Model.ProductName"
           onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
      <div class="img-placeholder rounded-3" style="display:none;height:320px;">
        <i class="bi bi-image text-secondary" style="font-size:4rem;"></i>
      </div>
    } else {
      <div class="img-placeholder rounded-3" style="height:320px;">
        <i class="bi bi-box-seam text-secondary" style="font-size:4rem;"></i>
      </div>
    }
  </div>
  <div class="col-md-7">
    <p class="text-muted small mb-1">@Model.Category?.CategoryName</p>
    <h2 class="fw-bold mb-2">@Model.ProductName</h2>

    @* Average rating display *@
    @{
      var visibleReviews = Model.Feedbacks.Where(f => f.Status == true).ToList();
      double avgRating = visibleReviews.Any() ? visibleReviews.Average(f => f.Rating ?? 0) : 0;
      int fullStars = (int)Math.Round(avgRating);
    }
    @if (visibleReviews.Any()) {
      <div class="d-flex align-items-center gap-2 mb-2">
        <div>
          @for (int i = 0; i < fullStars; i++) { <span class="text-warning fs-5">&#9733;</span> }
          @for (int i = fullStars; i < 5; i++) { <span class="text-muted fs-5">&#9733;</span> }
        </div>
        <span class="text-muted small">@avgRating.ToString("F1") / 5 &bull; @visibleReviews.Count review@(visibleReviews.Count != 1 ? "s" : "")</span>
      </div>
    }

    <h3 class="text-primary fw-bold mb-2">@Model.Price.ToString("N0") &#8363;</h3>
    <p class="mb-1">In stock: <strong class="text-success">@Model.Quantity</strong></p>
    <hr />
    <p class="text-muted">@Model.Description</p>
    <div class="d-flex gap-2">
      <a href="/Cart/Add/@Model.ProductId" class="btn btn-primary btn-lg px-4">
        <i class="bi bi-cart-plus me-1"></i>Add to Cart
      </a>
      <a href="/Product/Index" class="btn btn-outline-secondary btn-lg px-4">Back</a>
    </div>
  </div>
</div>

@* Customer Reviews *@
@if (visibleReviews.Any()) {
  <hr class="my-4" />
  <h5 class="section-title mb-3">Customer Reviews (@visibleReviews.Count)</h5>
  <div class="row row-cols-1 row-cols-md-2 g-3">
    @foreach (var f in visibleReviews) {
      <div class="col">
        <div class="card p-3 h-100">
          <div class="d-flex align-items-center gap-2 mb-2">
            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold"
                 style="width:36px;height:36px;flex-shrink:0;font-size:.9rem;">
              @(f.User?.FullName?.Length > 0 ? f.User.FullName[0].ToString().ToUpper() : "?")
            </div>
            <div>
              <div class="fw-semibold" style="font-size:.9rem;">@f.User?.FullName</div>
              <div>
                @for (int i = 0; i < (f.Rating ?? 0); i++) { <span class="text-warning">&#9733;</span> }
                @for (int i = (f.Rating ?? 0); i < 5; i++) { <span class="text-muted">&#9733;</span> }
              </div>
            </div>
            <small class="text-muted ms-auto">@f.CreatedAt?.ToString("dd/MM/yyyy")</small>
          </div>
          <p class="mb-0 text-muted">@f.Content</p>
        </div>
      </div>
    }
  </div>
}
