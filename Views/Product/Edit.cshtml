@model SWD392_MVC.Models.Product
@{ ViewData["Title"] = "Edit Product"; }
<div class="row justify-content-center"><div class="col-md-7"><div class="card p-4">
  <h4><i class="bi bi-pencil"></i> Edit Product</h4><hr/>
  <form method="post">
    <input type="hidden" name="ProductId" value="@Model.ProductId" />
    <div class="mb-3"><label class="form-label">Product Name</label><input name="ProductName" value="@Model.ProductName" class="form-control" required /></div>
    <div class="mb-3"><label class="form-label">Description</label><textarea name="Description" class="form-control" rows="3">@Model.Description</textarea></div>
    <div class="row">
      <div class="col mb-3"><label class="form-label">Price (₫)</label><input type="number" name="Price" value="@Model.Price" class="form-control" required /></div>
      <div class="col mb-3"><label class="form-label">Quantity</label><input type="number" name="Quantity" value="@Model.Quantity" class="form-control" required /></div>
    </div>
    <div class="mb-3"><label class="form-label">Category</label>
      <select name="CategoryId" class="form-select">
        @foreach (var c in (IList<SWD392_MVC.Models.ProductCategory>)ViewBag.Categories) {
          <option value="@c.CategoryId" selected="@(c.CategoryId == Model.CategoryId)">@c.CategoryName</option>
        }
      </select>
    </div>
    <div class="mb-3"><label class="form-label">Image URL</label><input name="ImageUrl" value="@Model.ImageUrl" class="form-control" /></div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a href="/Product/Manage" class="btn btn-outline-secondary ms-2">Cancel</a>
  </form>
</div></div></div>
