@model IList<SWD392_MVC.Models.Product>
@{
    ViewData["Title"] = "Products";
    // Read role from JWT to conditionally show cart button
    string? role = null;
    var jwtCookie = Context.Request.Cookies["jwt"];
    if (!string.IsNullOrEmpty(jwtCookie)) {
        try {
            var h = new System.IdentityModel.Tokens.Jwt.JwtSecurityTokenHandler();
            role = h.ReadJwtToken(jwtCookie).Claims.FirstOrDefault(c => c.Type == "UserRole")?.Value;
        } catch { }
    }
    bool canShop = role == null || role == "Customer";
}

<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="section-title mb-0"><i class="bi bi-grid me-2"></i>Products</h4>
  @if (canShop) {
    <a href="/Cart/Index" class="btn btn-outline-primary btn-sm">
      <i class="bi bi-cart3 me-1"></i>Cart
    </a>
  }
</div>

<!-- Search bar -->
<div class="card mb-4 p-3">
  <form method="get" class="row g-2 align-items-end">
    <div class="col-md-5">
      <label class="form-label mb-1">Search</label>
      <div class="input-group">
        <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
        <input name="search" value="@ViewBag.Search" class="form-control" placeholder="Search products..." />
      </div>
    </div>
    <div class="col-md-4">
      <label class="form-label mb-1">Category</label>
      <select name="categoryId" class="form-select">
        <option value="">All Categories</option>
        @foreach (var cat in (IList<SWD392_MVC.Models.ProductCategory>)ViewBag.Categories) {
                
                    @if (ViewBag.CategoryId?.ToString() == cat.CategoryId.ToString())
                    {
                        <option value="@cat.CategoryId" selected>@cat.CategoryName</option>
                    }
                    else
                    {
                        <option value="@cat.CategoryId">@cat.CategoryName</option>
                    }
        }
      </select>
    </div>
    <div class="col-md-3">
      <label class="form-label mb-1 d-none d-md-block">&nbsp;</label>
      <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search me-1"></i>Search</button>
    </div>
  </form>
</div>

@if (!Model.Any()) {
  <div class="empty-state">
    <span class="empty-icon">📦</span>
    <h5>No products found</h5>
    <p class="text-muted">Try adjusting your search or category filter.</p>
  </div>
} else {
  <div class="row row-cols-2 row-cols-md-4 g-3">
    @foreach (var p in Model) {
      <div class="col">
        <div class="card h-100 product-card">
          @if (!string.IsNullOrEmpty(p.ImageUrl)) {
            <img src="@p.ImageUrl" class="card-img-top" style="height:180px;object-fit:cover;border-radius:14px 14px 0 0;"
                 alt="@p.ProductName" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="img-placeholder" style="display:none">
              <i class="bi bi-image text-secondary" style="font-size:3rem;"></i>
            </div>
          } else {
            <div class="img-placeholder"><i class="bi bi-box-seam text-secondary" style="font-size:3rem;"></i></div>
          }
          <div class="card-body d-flex flex-column p-3">
            <small class="text-muted mb-1">@p.Category?.CategoryName</small>
            <h6 class="fw-bold mb-1" style="min-height:2.5rem;font-size:.93rem;">@p.ProductName</h6>
            <div class="price mb-1">@p.Price.ToString("N0") ₫</div>
            <div class="mb-2">
              <span class="stock-badge"><i class="bi bi-box me-1"></i>Còn @p.Quantity</span>
            </div>
            <div class="d-flex gap-2 mt-auto">
              <a href="/Product/Detail/@p.ProductId" class="btn btn-outline-secondary btn-sm flex-fill">Detail</a>
              @if (canShop) {
                <a href="/Cart/Add/@p.ProductId" class="btn btn-primary btn-sm flex-fill">
                  <i class="bi bi-cart-plus"></i> Add
                </a>
              }
            </div>
          </div>
        </div>
      </div>
    }
  </div>
}
