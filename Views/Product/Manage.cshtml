@model IList<SWD392_MVC.Models.Product>
@{ ViewData["Title"] = "Manage Products"; }
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4><i class="bi bi-box-seam"></i> Manage Products</h4>
  <a href="/Product/Create" class="btn btn-success"><i class="bi bi-plus"></i> Add Product</a>
</div>
<form method="get" class="row g-2 mb-3">
  <div class="col-md-4"><input name="search" value="@ViewBag.Search" class="form-control" placeholder="Search..." /></div>
  <div class="col-md-3">
    <select name="categoryId" class="form-select">
      <option value="">All Categories</option>
      @foreach (var c in (IList<SWD392_MVC.Models.ProductCategory>)ViewBag.Categories) {
        <option value="@c.CategoryId">@c.CategoryName</option>
      }
    </select>
  </div>
  <div class="col-md-2"><select name="status" class="form-select"><option value="">All</option><option value="true">Active</option><option value="false">Hidden</option></select></div>
  <div class="col-md-2"><button type="submit" class="btn btn-primary w-100">Filter</button></div>
</form>
<table class="table table-hover table-sm">
  <thead class="table-dark"><tr><th>Image</th><th>Name</th><th>Category</th><th>Price</th><th>Stock</th><th>Status</th><th>Actions</th></tr></thead>
  <tbody>
    @foreach (var p in Model) {
      <tr>
        <td>@if (!string.IsNullOrEmpty(p.ImageUrl)) { <img src="@p.ImageUrl" style="width:50px;height:50px;object-fit:cover;" class="rounded"/> }</td>
        <td>@p.ProductName</td><td>@p.Category?.CategoryName</td>
        <td>@p.Price.ToString("N0") ₫</td><td>@p.Quantity</td>
        <td><span class="badge @(p.Status==true?"bg-success":"bg-secondary")">@(p.Status==true?"Active":"Hidden")</span></td>
        <td>
          <a href="/Product/Edit/@p.ProductId" class="btn btn-sm btn-warning">Edit</a>
          <a href="/Product/ToggleStatus/@p.ProductId" class="btn btn-sm @(p.Status==true?"btn-secondary":"btn-success")">@(p.Status==true?"Hide":"Show")</a>
        </td>
      </tr>
    }
  </tbody>
</table>
