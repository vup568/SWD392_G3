@{
    string? userName = null;
    string? role     = null;
    var jwtCookie = Context.Request.Cookies["jwt"];
    if (!string.IsNullOrEmpty(jwtCookie))
    {
        try {
            var handler = new System.IdentityModel.Tokens.Jwt.JwtSecurityTokenHandler();
            var jwt     = handler.ReadJwtToken(jwtCookie);
            userName    = jwt.Claims.FirstOrDefault(c => c.Type == "UserName")?.Value;
            role        = jwt.Claims.FirstOrDefault(c => c.Type == "UserRole")?.Value;
        } catch { }
    }
    bool isStaff = role != null && role != "Customer";
    bool canShop = role == null || role == "Customer";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OnlineShop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        :root { --bs-primary: #1a56db; }
        body { font-family: 'Segoe UI', Arial, sans-serif; background: #f0f2f5; color: #1a1a2e; }
        /* ── Navbar ── */
        .navbar { background: linear-gradient(90deg,#1a56db,#1e40af) !important; box-shadow: 0 2px 12px rgba(26,86,219,.35); }
        .navbar-brand { font-weight: 800; font-size: 1.35rem; letter-spacing: -.3px; }
        .navbar .nav-link { font-weight: 500; border-radius: 8px; padding: .4rem .75rem !important; transition: background .15s; }
        .navbar .nav-link:hover { background: rgba(255,255,255,.18); }
        .navbar .badge { font-size: .7rem; border-radius: 20px; }
        /* ── Avatar circle ── */
        .avatar-circle { width:34px;height:34px;font-size:.9rem;flex-shrink:0;background:#fff;color:#1a56db;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700; }
        /* ── Dropdown ── */
        .dropdown-menu { border:none !important; box-shadow: 0 8px 32px rgba(0,0,0,.15) !important; border-radius:12px !important; padding:.5rem; }
        .dropdown-item { border-radius:8px; padding:.5rem .75rem; font-size:.9rem; }
        .dropdown-item:hover { background:#eff6ff; color:#1a56db; }
        .dropdown-header { font-size:.7rem; letter-spacing:.8px; color:#94a3b8; padding:.5rem .75rem .2rem; }
        /* ── Quick-access staff bar ── */
        .staff-bar { background:#fff; border-bottom:1px solid #e2e8f0; font-size:.82rem; }
        .staff-bar a { color:#475569; font-weight:500; text-decoration:none; padding:.3rem .6rem; border-radius:6px; transition:background .15s; }
        .staff-bar a:hover { background:#eff6ff; color:#1a56db; }
        /* ── Cards ── */
        .card { border:none !important; border-radius:14px !important; box-shadow: 0 1px 8px rgba(0,0,0,.07) !important; transition:transform .18s, box-shadow .18s; }
        .card:hover { transform:translateY(-3px); box-shadow: 0 6px 24px rgba(0,0,0,.12) !important; }
        /* ── Hero ── */
        .hero-banner { background: linear-gradient(135deg,#1a56db 0%,#6d28d9 100%); border-radius:20px; padding:4rem 2rem; color:#fff; text-align:center; margin-bottom:2.5rem; position:relative; overflow:hidden; }
        .hero-banner::before { content:''; position:absolute; inset:0; background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E"); }
        .hero-banner h1 { font-size:2.6rem; font-weight:800; position:relative; }
        .hero-banner p { font-size:1.1rem; opacity:.9; position:relative; }
        /* ── Section title ── */
        .section-title { font-size:1.25rem; font-weight:700; color:#1e293b; border-left:4px solid #1a56db; padding-left:.8rem; margin-bottom:1.25rem; }
        /* ── Product cards ── */
        .product-card { cursor:pointer; }
        .product-card .card-img-top { height:180px; object-fit:cover; border-radius:14px 14px 0 0 !important; }
        .product-card .price { font-size:1.05rem; font-weight:700; color:#1a56db; }
        .product-card .stock-badge { font-size:.75rem; background:#f0fdf4; color:#16a34a; border-radius:6px; padding:.1rem .5rem; font-weight:600; }
        /* ── Category pills ── */
        .cat-pill { border-radius:20px !important; font-size:.83rem; font-weight:600; padding:.35rem 1rem !important; border:1.5px solid #cbd5e1 !important; color:#475569 !important; background:#fff !important; transition:all .15s; }
        .cat-pill:hover, .cat-pill.active { background:#1a56db !important; color:#fff !important; border-color:#1a56db !important; }
        /* ── Auth card ── */
        .auth-card { border-radius:18px !important; box-shadow:0 10px 40px rgba(0,0,0,.13) !important; overflow:hidden; }
        .auth-header { background:linear-gradient(135deg,#1a56db,#6d28d9); color:#fff; padding:2rem; text-align:center; }
        /* ── Tables ── */
        .table thead th { background:#f8fafc; font-size:.78rem; text-transform:uppercase; letter-spacing:.6px; font-weight:700; color:#64748b; border:none; }
        .table td { vertical-align:middle; font-size:.9rem; }
        .table tbody tr:hover { background:#f8faff; }
        /* ── Stat cards ── */
        .stat-card { border-radius:16px !important; border:none !important; overflow:hidden; }
        .stat-card .stat-icon { font-size:2.5rem; opacity:.2; }
        .stat-card .stat-val { font-size:2rem; font-weight:800; }
        .stat-card .stat-lbl { font-size:.8rem; text-transform:uppercase; letter-spacing:.6px; opacity:.75; font-weight:600; }
        /* ── Buttons ── */
        .btn { border-radius:9px; font-weight:600; font-size:.88rem; }
        .btn-primary { background:#1a56db; border-color:#1a56db; }
        .btn-primary:hover { background:#1e40af; border-color:#1e40af; transform:translateY(-1px); }
        /* ── Forms ── */
        .form-control, .form-select { border-radius:9px; border:1.5px solid #e2e8f0; font-size:.92rem; }
        .form-control:focus, .form-select:focus { border-color:#1a56db; box-shadow:0 0 0 3px rgba(26,86,219,.12); }
        .form-label { font-weight:600; font-size:.88rem; color:#374151; }
        /* ── Badges ── */
        .badge { border-radius:8px; font-size:.75rem; font-weight:600; }
        /* ── Alert ── */
        .alert { border:none; border-radius:12px; }
        /* ── Footer ── */
        footer { background:#fff; border-top:1px solid #e2e8f0; color:#64748b; font-size:.87rem; margin-top:4rem; padding:1.5rem 0; }
        /* ── Sidebar nav ── */
        .side-nav .nav-link { border-radius:10px; color:#374151; font-weight:500; padding:.55rem .9rem; margin-bottom:.2rem; }
        .side-nav .nav-link:hover, .side-nav .nav-link.active { background:#eff6ff; color:#1a56db; }
        /* ── Status badges ── */
        .status-submitted  { background:#fef9c3; color:#854d0e; }
        .status-processing { background:#e0f2fe; color:#0369a1; }
        .status-completed  { background:#dcfce7; color:#15803d; }
        .status-cancelled  { background:#fee2e2; color:#b91c1c; }
        /* ── Image placeholder ── */
        .img-placeholder { height:180px; background:linear-gradient(135deg,#f1f5f9,#e2e8f0); display:flex; align-items:center; justify-content:center; border-radius:14px 14px 0 0; }
        /* ── Empty state ── */
        .empty-state { text-align:center; padding:4rem 1rem; color:#94a3b8; }
        .empty-icon { font-size:4rem; margin-bottom:1rem; display:block; }
    </style>
</head>
<body>

<!-- ═══ NAVBAR ═══ -->
<nav class="navbar navbar-expand-lg navbar-dark">
  <div class="container">
    <a class="navbar-brand" href="/"><i class="bi bi-shop-window me-2"></i>OnlineShop</a>
    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link" href="/Product/Index"><i class="bi bi-grid me-1"></i>Products</a></li>
        <li class="nav-item"><a class="nav-link" href="/Blog/Index"><i class="bi bi-newspaper me-1"></i>Blog</a></li>
        @if (role == "Sale" || role == "Admin") {
          <li class="nav-item"><a class="nav-link" href="/Product/Manage"><i class="bi bi-box me-1"></i>Manage Products</a></li>
          <li class="nav-item"><a class="nav-link" href="/Order/Manage"><i class="bi bi-clipboard-check me-1"></i>Orders</a></li>
        }
        @if (role == "Marketing" || role == "Admin") {
          <li class="nav-item"><a class="nav-link" href="/Blog/Manage"><i class="bi bi-pencil-square me-1"></i>Manage Posts</a></li>
        }
        @if (role == "Admin") {
          <li class="nav-item"><a class="nav-link" href="/Dashboard/Admin"><i class="bi bi-speedometer2 me-1"></i>Admin</a></li>
        }
      </ul>
      <ul class="navbar-nav align-items-center gap-1">
        @if (canShop) {
          <li class="nav-item">
            <a class="nav-link position-relative" href="/Cart/Index">
              <i class="bi bi-cart3 fs-5"></i><span class="ms-1 d-none d-lg-inline">Cart</span>
            </a>
          </li>
        }
        @if (userName == null) {
          <li class="nav-item ms-1"><a class="btn btn-outline-light btn-sm px-3" href="/Account/Login">Login</a></li>
          <li class="nav-item ms-1"><a class="btn btn-light btn-sm px-3 fw-semibold" style="color:#1a56db" href="/Account/Register">Register</a></li>
        } else {
          <li class="nav-item dropdown ms-1">
            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 py-1 px-2 rounded-pill" 
               style="background:rgba(255,255,255,.15)" href="#" data-bs-toggle="dropdown">
              <span class="avatar-circle">@(userName.Length > 0 ? userName[0].ToString().ToUpper() : "U")</span>
              <span class="d-none d-lg-inline fw-semibold">@userName</span>
              <span class="badge bg-warning text-dark d-none d-lg-inline">@role</span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end" style="min-width:230px">
              <li class="px-3 py-2 border-bottom mb-1">
                <div class="fw-bold text-dark">@userName</div>
                <small class="text-muted">@role</small>
              </li>
              <li><a class="dropdown-item" href="/Account/Profile"><i class="bi bi-person me-2 text-primary"></i>My Profile</a></li>
              <li><a class="dropdown-item" href="/Account/ChangePassword"><i class="bi bi-key me-2 text-primary"></i>Change Password</a></li>
              @if (role == "Customer") {
                <li><a class="dropdown-item" href="/Order/MyOrders"><i class="bi bi-bag-check me-2 text-primary"></i>My Orders</a></li>
              }
              @if (role == "Marketing" || role == "Admin") {
                <li><hr class="dropdown-divider my-1"></li>
                <li><span class="dropdown-header">MARKETING</span></li>
                <li><a class="dropdown-item" href="/Dashboard/Marketing"><i class="bi bi-graph-up me-2"></i>Dashboard</a></li>
                <li><a class="dropdown-item" href="/Blog/Manage"><i class="bi bi-pencil-square me-2"></i>Manage Posts</a></li>
                <li><a class="dropdown-item" href="/Marketing/Sliders"><i class="bi bi-image me-2"></i>Sliders</a></li>
                <li><a class="dropdown-item" href="/Marketing/Customers"><i class="bi bi-people me-2"></i>Customers</a></li>
                <li><a class="dropdown-item" href="/Marketing/Feedbacks"><i class="bi bi-chat-dots me-2"></i>Reviews</a></li>
              }
              @if (role == "Sale" || role == "Admin") {
                <li><hr class="dropdown-divider my-1"></li>
                <li><span class="dropdown-header">SALES</span></li>
                <li><a class="dropdown-item" href="/Dashboard/Sales"><i class="bi bi-graph-up-arrow me-2"></i>Dashboard</a></li>
                <li><a class="dropdown-item" href="/Product/Manage"><i class="bi bi-box me-2"></i>Manage Products</a></li>
                <li><a class="dropdown-item" href="/Order/Manage"><i class="bi bi-clipboard-check me-2"></i>Orders</a></li>
              }
              @if (role == "Admin") {
                <li><hr class="dropdown-divider my-1"></li>
                <li><span class="dropdown-header">ADMIN</span></li>
                <li><a class="dropdown-item" href="/Dashboard/Admin"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</a></li>
                <li><a class="dropdown-item" href="/Dashboard/Users"><i class="bi bi-people-fill me-2"></i>User Management</a></li>
                <li><a class="dropdown-item" href="/Config/Categories"><i class="bi bi-tags me-2"></i>Categories</a></li>
                <li><a class="dropdown-item" href="/Config/Settings"><i class="bi bi-gear me-2"></i>Settings</a></li>
              }
              <li><hr class="dropdown-divider my-1"></li>
              <li><a class="dropdown-item text-danger fw-semibold" href="/Account/Logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
            </ul>
          </li>
        }
      </ul>
    </div>
  </div>
</nav>

<!-- ═══ MAIN CONTENT ═══ -->
<div class="container py-4">
  @if (TempData["Success"] != null) {
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 shadow-sm" role="alert">
      <i class="bi bi-check-circle-fill fs-5 text-success"></i><span>@TempData["Success"]</span>
      <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
  }
  @if (TempData["Error"] != null) {
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 shadow-sm" role="alert">
      <i class="bi bi-exclamation-triangle-fill fs-5"></i><span>@TempData["Error"]</span>
      <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
  }
  @RenderBody()
</div>

<!-- ═══ FOOTER ═══ -->
<footer>
  <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
    <div class="d-flex align-items-center gap-2">
      <i class="bi bi-shop-window text-primary fs-5"></i>
      <strong class="text-dark">OnlineShop</strong>
      <span>&copy; 2026 — SWD392 Group 3</span>
    </div>
    <span>Built with ASP.NET Core 8 &amp; Bootstrap 5</span>
  </div>
</footer>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
